@model SmashAdvanced.Models.Game

@{
    ViewData["Title"] = "Details";
}

<div class="container">

    <!-- Top Banner -->
    <div class="row">
        <img src="/images/game-splat.jpeg" alt="Game Cover">
        <div class="hero-info">
            <h1>@Html.DisplayFor(model => model.Name)</h1>
            <div class="tags">
                @foreach (var gameTag in Model.GameTags)
                {
                    <span>@gameTag.Tag.Name</span>
                }
            </div>
        </div>
    </div>

    <div class="row">

        <!-- MAIN CONTENT -->
        <div class="col">

            <section>
                <h2>About the Game</h2>
                <p>
                    @Html.DisplayFor(model => model.Description)
                </p>
            </section>

            <section class="features">
                <h2>Features</h2>
                <ul>
                    @foreach (var gameFeature in Model.GameFeatures)
                    {
                        <li>@gameFeature.GameFeatureText</li>
                    }
                </ul>
            </section>

            <section>
                <h2>Screenshots</h2>
                <div class="gallery">
                    @foreach (var screenshot in Model.GameScreenshots)
                    {
                        <img src="@screenshot.GameScreenshotUrl" alt="@screenshot.GameScreenshotDescription">
                    }
                </div>
            </section>

            <section>
                <h2>Devlog</h2>
                <div class="devlog-entry">
                    <strong>Update 1.1</strong>
                    <p>Added new level and improved enemy AI.</p>
                </div>
                <div class="devlog-entry">
                    <strong>Launch Day</strong>
                    <p>The game is officially released!</p>
                </div>
            </section>

        </div>

        <!-- SIDEBAR -->
        <div class="col">
            <div class="price">@Model.RetailPrice</div>
            <a href="@Model.DownloadUrl" class="button">Download Now</a>
            <a href="#" class="button" style="background:#333;">Add to Collection</a>

            <div class="meta">
                <p><strong>Status:</strong> @Model.ReleaseStatus</p>
                <p><strong>Platform:</strong> 
                    @foreach (var platform in Model.GamePlatforms)
                    {
                        @platform.Platform.PlatformName
                    }
                </p>
                <p><strong>Author:</strong> @Model.Author</p>
                <p><strong>Updated:</strong> @Model.LastUpdated</p>
            </div>
        </div>

    </div>

</div>


