@model IEnumerable<SmashAdvanced.Models.GameScreenshot>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.GameScreenshotUrl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GameScreenshotDescription)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.GameScreenshotUrl)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GameScreenshotDescription)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.GameScreenshotId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.GameScreenshotId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.GameScreenshotId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
